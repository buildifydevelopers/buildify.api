# ── LLM Provider ──
# Options: auto | cerebras | gemini
# auto = use Cerebras if key is set, otherwise Gemini
LLM_PROVIDER=cerebras

# ── Cerebras API ──
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_MIN_INTERVAL_SECONDS=2.5

# ── Gemini API (optional fallback) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Authentication ──
# Leave empty to disable auth (development mode)
# Set a token to require X-API-Key header on all endpoints
API_AUTH_TOKEN=

# ── Database ──
# SQLite (default, good for local dev)
PB_DATABASE_URL=sqlite+aiosqlite:///./project_builder.db

# PostgreSQL (for production)
# PB_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/project_builder

# ── CORS ──
# JSON array of allowed origins, or ["*"] for all
CORS_ORIGINS=["*"]

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=10

# ── Cache ──
# Cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600
